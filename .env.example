# ─────────────────────────────────────────────
# Nistula Guest Message Handler — Environment
# ─────────────────────────────────────────────
# Copy this file to .env and fill in real values.
# Never commit .env to version control.

# Anthropic Claude API key
ANTHROPIC_API_KEY=sk-ant-your-key-here

# PostgreSQL connection string (Part 2)
DATABASE_URL=postgresql://user:password@localhost:5432/nistula

# App settings
APP_ENV=development
PORT=8000
